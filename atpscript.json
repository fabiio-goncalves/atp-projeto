print("═══ NORMALIZANDO COUNTRYCODE ═══");

const historicalCountries = [
    { Code: "CS", Name: "Czechoslovakia" },
    { Code: "YU", Name: "Yugoslavia" },
    { Code: "XK", Name: "Kosovo" },
    { Code: "TW", Name: "Taiwan" },
    { Code: "UNK", Name: "Unknown" }
];

historicalCountries.forEach(country => {
    db.CountryCode.updateOne(
        { Code: country.Code },
        { $setOnInsert: country },
        { upsert: true }

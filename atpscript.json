print("═══ VERIFICANDO E IMPORTANDO DADOS ═══\n");

const dataPath = "c:/data/atp/";
const collections = [
    { name: "CountryCode", file: "countries_net.csv" },
    { name: "player_db", file: "player_db.csv" },
    { name: "World_Cities", file: "World_Cities.csv" },
    { name: "cities", file: "cities.csv" }
];

function importCollection(collectionName, fileName) {
    const fullPath = dataPath + fileName;
    const exists = db.getCollection(collectionName).countDocuments();
    
    if (exists > 0) {
        print(`✓ ${collectionName} já existe (${exists} documentos)`);
        return true;
    }
    
    print(`→ Importando ${collectionName} de ${fileName}...`);
    
    try {
        // Usar função nativa do mongosh para ler CSV
        const result = cat(fullPath);
        if (!result) {
            print(`  ⚠ AVISO: Não foi possível ler ${fullPath}`);
            print(`  → Execute manualmente: mongoimport --db atpplayers --collection ${collectionName} --type csv --headerline --file "${fullPath}"`);
            return false;
        }
        
        // Parse CSV manualmente
        const lines = result.split('\n');
        const headers = lines[0].split(',').map(h => h.trim());
        const documents = [];
        
        for (let i = 1; i < lines.length; i++) {
            if (lines[i].trim() === '') continue;
            
            const values = lines[i].split(',');
            const doc = {};
            
            for (let j = 0; j < headers.length; j++) {
                doc[headers[j]] = values[j] ? values[j].trim() : "";
            }
            
            documents.push(doc);
        }
        
        if (documents.length > 0) {
            db.getCollection(collectionName).insertMany(documents);
            print(`  ✓ ${documents.length} documentos importados`);
            return true;
        }
    } catch (e) {
        print(`  ⚠ ERRO ao importar ${collectionName}: ${e.message}`);
        print(`  → Execute manualmente: mongoimport --db atpplayers --collection ${collectionName} --type csv --headerline --file "${dataPath}${fileName}"`);
        return false;
    }
    
    return false;
}


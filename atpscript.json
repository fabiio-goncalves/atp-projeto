// 4. CRIAÇÃO DE PLAYERS
// ============================================================================

print("═══ CRIANDO COLEÇÃO PLAYERS ═══");

db.atpplayers.aggregate([
    {
        $group: {
            _id: "$LinkPlayer",
            PlayerName: { $first: "$PlayerName" },
            Born: { $first: "$Born" },
            Height: { $first: "$Height" },
            Hand: { $first: "$Hand" },
            LinkPlayer: { $first: "$LinkPlayer" }
        }
    },
    {
        $project: {
            _id: 0,
            LinkPlayer: 1,
            PlayerName: 1,
            Born: 1,
            Height: 1,
            Hand: 1
        }
    },
    {
        $merge: {
            into: "Players",
            on: "LinkPlayer",
            whenMatched: "keepExisting",
            whenNotMatched: "insert"
        }
    }
], { allowDiskUse: true });

const playerCount = db.Players.countDocuments();

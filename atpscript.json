});

db.CountryCode.updateOne({ Code: "VN" }, { $set: { Name: "Vietnam" } });

// Simplificar nomes de países com vírgula (ex: "Iran, Islamic Republic of" → "Iran")
// Exceto: "Korea, Democratic People's Republic of" (Coreia do Norte)
db.CountryCode.updateMany(
    {
        Name: { $regex: /,/ },
        Name: { $ne: "Korea, Democratic People's Republic of" }
    },
    [
        {
            $set: {
                Name: {
                    $trim: {
                        input: { $arrayElemAt: [{ $split: ["$Name", ","] }, 0] }
                    }
                }
            }
        }
    ]
);

const countryCount = db.CountryCode.countDocuments();
print(`✓ ${countryCount} códigos de países normalizados\n`);

// ============================================================================
// 3. PREPARAÇÃO DE WORLD_CITIES
// ============================================================================

print("═══ PREPARANDO WORLD_CITIES ═══");

// Adicionar CountryCode às cidades (sem normalização - será feito nos Tournaments)
db.World_Cities.aggregate([
    {
        $lookup: {
            from: "CountryCode",
            localField: "Country",
            foreignField: "Name",
            as: "countryInfo"
        }
    },
    {
        $set: {
            CountryCode: { $arrayElemAt: ["$countryInfo.Code", 0] }
        }
    },
    {
        $project: { countryInfo: 0 }
    },
    {
        $merge: {
            into: "World_Cities",
            on: "_id",
            whenMatched: "merge"
        }
    }
], { allowDiskUse: true });

const cityCount = db.World_Cities.countDocuments();

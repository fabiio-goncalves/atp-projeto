Object.entries(tournamentCountryMap).forEach(([wrong, correct]) => {
    db.Tournaments.updateMany({ TournamentCountry: wrong }, { $set: { TournamentCountry: correct } });
});

print("✓ Países normalizados");

// Estados dos EUA (siglas de 2 letras)
db.Tournaments.updateMany(
    { TournamentCountry: { $regex: /^[A-Z]{2}$/ } }, 
    { $set: { TournamentCountry: "United States" } }
);

print("✓ Estados US normalizados\n");

print("═══ MATCHING TOURNAMENTS → COUNTRYCODE ═══");

let matchedByCountryCode = 0;
let matchedByWorldCities = 0;
let matchedByCityLookup = 0;

// 1. Match direto por TournamentCountry em CountryCode
db.Tournaments.aggregate([
    {
        $match: { 
            $and: [
                { $or: [{ CountryCode: { $exists: false } }, { CountryCode: null }, { CountryCode: "" }] },
                { TournamentCountry: { $ne: null, $ne: "" } }
            ]
        }
    },
    {
        $lookup: {
            from: "CountryCode",
            let: { country: "$TournamentCountry" },
            pipeline: [
                {
                    $match: {
                        $expr: {
                            $eq: [
                                { $toLower: "$Name" },
                                { $toLower: "$$country" }
                            ]
                        }
                    }
                }
            ],
            as: "match"
        }
    },
    {
        $match: { match: { $ne: [] } }
    },
    {
        $set: { CountryCode: { $arrayElemAt: ["$match.Code", 0] } }
    },
    {
        $project: { match: 0 }
    },
    {
        $merge: { into: "Tournaments", on: "_id", whenMatched: "merge" }
    }
], { allowDiskUse: true });

matchedByCountryCode = db.Tournaments.countDocuments({ 
    CountryCode: { $nin: [null, "", "UNK"] } 
});
print(`→ ${matchedByCountryCode} matched via CountryCode`);

// 2. Match por TournamentCountry como Country em World_Cities
const pendingAfterCountryCode = db.Tournaments.countDocuments({
    $or: [{ CountryCode: { $exists: false } }, { CountryCode: null }, { CountryCode: "" }]
});
print(`→ ${pendingAfterCountryCode} torneios ainda sem CountryCode`);

let candidatesForWorldCitiesCountry = 0;
db.Tournaments.find({
    $or: [{ CountryCode: { $exists: false } }, { CountryCode: null }, { CountryCode: "" }],
    TournamentCountry: { $ne: null, $ne: "", $exists: true }
}).forEach(tournament => {
    // Validar que TournamentCountry existe e não é undefined
    if (!tournament.TournamentCountry) return;
    
    candidatesForWorldCitiesCountry++;
    
    const cityDoc = db.World_Cities.findOne({
        Country: { $regex: new RegExp("^" + tournament.TournamentCountry.trim() + "$", "i") }
    });
    
    if (cityDoc?.CountryCode) {
        db.Tournaments.updateOne(
            { _id: tournament._id },
            { $set: { CountryCode: cityDoc.CountryCode } }
        );
        matchedByWorldCities++;
    }
});

print(`→ ${candidatesForWorldCitiesCountry} candidatos verificados em World_Cities.Country`);
print(`→ ${matchedByWorldCities} matched via World_Cities.Country`);

// 3. Match por TournamentCity em World_Cities
let candidatesForWorldCitiesCity = 0;
db.Tournaments.find({
    $or: [{ CountryCode: { $exists: false } }, { CountryCode: null }, { CountryCode: "" }],
    TournamentCity: { $ne: null, $ne: "", $exists: true }
}).forEach(tournament => {
    // Validar que TournamentCity existe e não é undefined
    if (!tournament.TournamentCity) return;
    
    candidatesForWorldCitiesCity++;
    
    const cityDoc = db.World_Cities.findOne({
        City: { $regex: new RegExp("^" + tournament.TournamentCity.trim() + "$", "i") }
    });
    
    if (cityDoc?.CountryCode) {
        db.Tournaments.updateOne(
            { _id: tournament._id },
            { $set: { CountryCode: cityDoc.CountryCode } }
        );
        matchedByCityLookup++;
    }
});

print(`→ ${candidatesForWorldCitiesCity} candidatos verificados em World_Cities.City`);
print(`→ ${matchedByCityLookup} matched via World_Cities.City`);

const totalMatched = matchedByCountryCode + matchedByWorldCities + matchedByCityLookup;
print(`✓ Total matched: ${totalMatched}\n`);

// 4. Atribuir UNK aos restantes
const unkTournaments = db.Tournaments.updateMany(
    { $or: [{ CountryCode: { $exists: false } }, { CountryCode: null }, { CountryCode: "" }] },
    { $set: { CountryCode: "UNK" } }
);

print(`✓ ${unkTournaments.modifiedCount} torneios com 'UNK'\n`);

// ============================================================================
// 12. CRIAÇÃO DE PLAYER_PER_GAME
// ============================================================================

print("═══ CRIANDO PLAYER_PER_GAME ═══");

print("→ Criando mapas...");
const playerMapById = {};
const tournamentMapById = {};

db.Players.find({}, { PlayerName: 1, _id: 1 }).forEach(p => {
    playerMapById[p.PlayerName] = p._id.toString();
});

db.Tournaments.find({}, { Tournament: 1, _id: 1 }).forEach(t => {
    tournamentMapById[t.Tournament] = t._id.toString();
});

print(`  ✓ ${Object.keys(playerMapById).length} players`);
print(`  ✓ ${Object.keys(tournamentMapById).length} tournaments\n`);

const totalDocs = db.atpplayers.countDocuments();
const insertBatchSize = 5000;
let processed = 0;
let inserted = 0;
let bulk = [];

print(`→ Processando ${totalDocs} documentos...`);

db.atpplayers.find().forEach(doc => {
    const playerId = playerMapById[doc.PlayerName];
    const tournamentId = tournamentMapById[doc.Tournament];
    
    if (playerId && tournamentId) {
        bulk.push({
            player_mongo_id: playerId,
            tournament_mongo_id: tournamentId,
            GameRound: doc.GameRound,
            GameRank: doc.GameRank,
            Oponent: doc.Oponent,
            WL: doc.WL,
            Score: doc.Score
        });
    }
    
    processed++;
    
    if (bulk.length >= insertBatchSize) {
        try {
            db.Player_Per_Game.insertMany(bulk, { ordered: false });
            inserted += bulk.length;
            if (processed % 50000 === 0) {
                print(`  ${((processed/totalDocs)*100).toFixed(1)}% - ${inserted} inseridos`);
            }
        } catch (e) {
            if (!e.message.includes("duplicate")) {
                print("  ⚠ Erro: " + e.message);
            }
        }
        bulk = [];
    }
});

if (bulk.length > 0) {
    try {
        db.Player_Per_Game.insertMany(bulk, { ordered: false });
        inserted += bulk.length;
    } catch (e) {}
}

print(`✓ ${inserted} jogos inseridos\n`);

// ============================================================================
// 13. LIMPEZA FINAL
// ============================================================================

print("═══ LIMPEZA FINAL ═══");

// Remover byes
const byeResult = db.Player_Per_Game.deleteMany({ Oponent: "bye" });
print(`✓ ${byeResult.deletedCount} byes removidos`);

// Remover duplicados
const beforeDup = db.Player_Per_Game.countDocuments();
const duplicates = [];

db.Player_Per_Game.aggregate([
    {
        $group: {
            _id: {
                player: "$player_mongo_id",
                tournament: "$tournament_mongo_id",
                round: "$GameRound",
                opponent: "$Oponent",
                wl: "$WL",
                score: "$Score"
            },
            ids: { $addToSet: "$_id" },
            count: { $sum: 1 }
        }
    },
    {
        $match: { count: { $gt: 1 } }
    }
], { allowDiskUse: true }).forEach(doc => {
    doc.ids.shift();
    duplicates.push(...doc.ids);
});

if (duplicates.length > 0) {
    db.Player_Per_Game.deleteMany({ _id: { $in: duplicates } });
}

const afterDup = db.Player_Per_Game.countDocuments();
print(`✓ ${beforeDup - afterDup} duplicados removidos`);

// Normalizar Score
db.Player_Per_Game.aggregate([
    {
        $addFields: {
            ScoreSets: {
                $split: [
                    { $trim: { input: { $replaceAll: { input: { $toString: "$Score" }, find: ",", replacement: " " } } } },
                    " "
                ]
            },
            WL_Bool: { $cond: [{ $eq: ["$WL", "W"] }, 1, 0] }
        }
    },
    {
        $project: { WL: 0 }
    },
    {
        $merge: { into: "Player_Per_Game", on: "_id", whenMatched: "merge" }
    }
], { allowDiskUse: true });

print("✓ Scores normalizados\n");

// ============================================================================
// 14. ESTATÍSTICAS FINAIS
// ============================================================================

print("\n═══ ESTATÍSTICAS FINAIS ═══\n");

const stats = {
    players: db.Players.countDocuments(),
    playersWithCode: db.Players.countDocuments({ CountryCode: { $nin: [null, "", "UNK"] } }),
    tournaments: db.Tournaments.countDocuments(),
    tournamentsWithCode: db.Tournaments.countDocuments({ CountryCode: { $nin: [null, "", "UNK"] } }),
    games: db.Player_Per_Game.countDocuments()
};

print(`Players: ${stats.players}`);
print(`  → Com CountryCode: ${stats.playersWithCode} (${(stats.playersWithCode/stats.players*100).toFixed(1)}%)\n`);

print(`Tournaments: ${stats.tournaments}`);
print(`  → Com CountryCode: ${stats.tournamentsWithCode} (${(stats.tournamentsWithCode/stats.tournaments*100).toFixed(1)}%)\n`);

print(`Player_Per_Game: ${stats.games} jogos\n`);

print("Top 5 países (Players):");
db.Players.aggregate([

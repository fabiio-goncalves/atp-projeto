// ============================================================================
// 5. DIVIDINDO CAMPOS COMPOSTOS
// ============================================================================

print("═══ PROCESSANDO CAMPOS COMPOSTOS ═══");

// Hand → FrontHand + BackHand
db.Players.aggregate([
    {
        $addFields: {
            FrontHand: { $arrayElemAt: [{ $split: ["$Hand", ", "] }, 0] },
            BackHand: { $arrayElemAt: [{ $split: ["$Hand", ", "] }, 1] }
        }
    },
    {
        $project: { Hand: 0 }
    },
    {
        $merge: {
            into: "Players",
            on: "_id",
            whenMatched: "merge"
        }
    }
], { allowDiskUse: true });

// Born → BornCity + BornCountry
db.Players.updateMany(
    {},
    [
        {
            $set: {
                parts: { $split: ["$Born", ","] },
                numParts: { $size: { $split: ["$Born", ","] } }
            }
        },
        {
            $set: {
                BornCity: {
                    $cond: [
                        { $gte: ["$numParts", 2] },
                        { $trim: { input: { $arrayElemAt: ["$parts", 0] } } },
                        ""
                    ]
                },
                BornCountry: {
                    $cond: [
                        { $eq: ["$numParts", 1] },
                        { $trim: { input: { $arrayElemAt: ["$parts", 0] } } },
                        { $trim: { input: { $arrayElemAt: ["$parts", -1] } } }
                    ]
                }
            }
        },
        {
            $unset: ["parts", "numParts", "Born"]
        }
    ]
);

print("✓ Campos divididos\n");

// ============================================================================
// 6. MATCHING PLAYERS COM PLAYER_DB
// ============================================================================

print("═══ MATCHING PLAYERS → COUNTRYCODE ═══");

let matched = 0;
let total = 0;
const batchSize = 1000;

// Cache do player_db
const playerDbCache = {};
db.player_db.find({}, { full_name: 1, iso2: 1, name_first: 1, name_last: 1 }).forEach(p => {
    if (p.full_name) playerDbCache[p.full_name.toLowerCase()] = p.iso2;
    const key = (p.name_first + " " + p.name_last).toLowerCase();
    if (!playerDbCache[key]) playerDbCache[key] = p.iso2;
});

print(`→ Cache: ${Object.keys(playerDbCache).length} entradas`);

db.Players.find({ $or: [{ CountryCode: { $exists: false } }, { CountryCode: null }, { CountryCode: "" }] })
    .forEach(player => {
        total++;
        
        if (!player.PlayerName) return;
        
        const normalized = player.PlayerName
            .replace(/[\.\-]/g, "")
            .replace(/\s+/g, " ")
            .trim()
            .toLowerCase();
        
        if (playerDbCache[normalized]) {
            db.Players.updateOne(
                { _id: player._id },
                { $set: { CountryCode: playerDbCache[normalized] } }
            );
            matched++;
        }
        
        if (total % batchSize === 0) {
            print(`  ${total} processados | ${matched} matched`);
        }
    });

print(`✓ ${matched}/${total} matched via player_db\n`);

// ============================================================================
// 7. MATCHING POR BORNCOUNTRY
// ============================================================================

print("═══ MATCHING POR PAÍS DE NASCIMENTO ═══");

const hardcodeMap = {
    "Czechoslovakia": "CS", "Yugoslavia": "YU", "Chinese Taipei": "TW",
    "New York": "US", "Illinois": "US", "Tennessee": "US", "North Carolina": "US",
    "Slovak Republic": "SK", "Bosnia-Herzegovina": "BA", "Bosnia": "BA",
    "Hong Kong": "HK", "Lisboa": "PT", "Sao Paulo": "BR", "São Paulo": "BR",
    "Tahiti": "PF", "AUS": "AU", "RSA": "ZA", "Korea (South)": "KR",
    "Czech Rep.": "CZ", "ARG": "AR", "U.S.A.": "US", "Great Britain": "GB",
    "The Netherlands": "NL", "Korea": "KR", "Bahamas": "BS", "Kiev": "UA",
    "Brasil": "BR", "Moscow": "RU", "Russia": "RU"
};

let countryMatched = 0;

db.Players.find({ 
    $or: [{ CountryCode: { $exists: false } }, { CountryCode: null }, { CountryCode: "" }],
    BornCountry: { $ne: null, $ne: "" }
}).forEach(player => {
    const country = player.BornCountry.trim();
    
    // Match direto
    let countryDoc = db.CountryCode.findOne({ Name: { $regex: new RegExp("^" + country + "$", "i") } });
    
    if (countryDoc?.Code) {
        db.Players.updateOne({ _id: player._id }, { $set: { CountryCode: countryDoc.Code } });
        countryMatched++;
        return;
    }
    
    // Por cidade
    if (player.BornCity) {
        let cityDoc = db.World_Cities.findOne({ City: { $regex: new RegExp("^" + player.BornCity + "$", "i") } });
        if (cityDoc?.CountryCode) {
            db.Players.updateOne({ _id: player._id }, { $set: { CountryCode: cityDoc.CountryCode } });
            countryMatched++;
            return;
        }
    }
    
    // Hardcode
    if (hardcodeMap[country]) {
        db.Players.updateOne({ _id: player._id }, { $set: { CountryCode: hardcodeMap[country] } });
        countryMatched++;
        return;
    }
    
    // Siglas → USA
    if (/^[A-Z]{2}$/.test(country)) {
        db.Players.updateOne({ _id: player._id }, { $set: { CountryCode: "US" } });
        countryMatched++;
    }
});

print(`✓ ${countryMatched} matched por país\n`);


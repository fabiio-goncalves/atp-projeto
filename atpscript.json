            _id: { tournament: "$Tournament", date: "$Date" },
            Tournament: { $first: "$Tournament" },
            Location: { $first: "$Location" },
            Date: { $first: "$Date" },
            Ground: { $first: "$Ground" },
            Prize: { $first: "$Prize" }
        }
    },
    {
        $project: { _id: 0 }
    },
    {
        $merge: {
            into: "Tournaments",
            on: ["Tournament", "Date"],
            whenMatched: "keepExisting",
            whenNotMatched: "insert"
        }
    }
], { allowDiskUse: true });

// Remover datas inválidas
db.Tournaments.deleteMany({
    $expr: {
        $let: {
            vars: { dateStart: { $arrayElemAt: [{ $split: ["$Date", " - "] }, 0] } },
            in: {
                $or: [
                    { $lt: [{ $dateFromString: { dateString: "$$dateStart", format: "%Y.%m.%d", onError: null } }, ISODate("1973-03-28")] },
                    { $gt: [{ $dateFromString: { dateString: "$$dateStart", format: "%Y.%m.%d", onError: null } }, ISODate("2022-02-14")] },
                    { $eq: [{ $dateFromString: { dateString: "$$dateStart", format: "%Y.%m.%d", onError: null } }, null] }
                ]
            }
        }
    }
});

const tournamentCount = db.Tournaments.countDocuments();
print(`✓ ${tournamentCount} torneios criados\n`);

// ============================================================================
// 10. PROCESSAMENTO DE TOURNAMENTS
// ============================================================================

print("═══ PROCESSANDO TOURNAMENTS ═══");

// Location → City + Country + Extração de F-number (tudo junto)
db.Tournaments.aggregate([
    {
        $addFields: {
            locationParts: { $split: ["$Location", ", "] },
            numParts: { $size: { $split: ["$Location", ", "] } },
            // Detectar se Tournament termina com " F" + número
            fnumberMatch: {
                $regexFind: {
                    input: { $ifNull: ["$Tournament", ""] },
                    regex: /\s+F\d+$/i
                }
            }
        }
    },
    {
        $addFields: {
            TournamentCity: {
                $cond: [
                    { $eq: ["$numParts", 1] },
                    "",
                    { $arrayElemAt: ["$locationParts", 0] }
                ]
            },
            TournamentCountry: {
                $cond: [
                    // Se encontrou padrão F-number
                    { $ne: ["$fnumberMatch", null] },
                    // Extrair tudo antes do " F[número]"
                    {
                        $trim: {
                            input: {
                                $substr: [
                                    "$Tournament",
                                    0,
                                    "$fnumberMatch.idx"
                                ]
                            }
                        }
                    },
                    // Senão, extrai do Location
                    {
                        $cond: [
                            { $eq: ["$numParts", 1] },
                            { $arrayElemAt: ["$locationParts", 0] },
                            { $arrayElemAt: ["$locationParts", -1] }
                        ]
                    }
                ]
            }
        }
    },
    {
        $project: { Location: 0, locationParts: 0, numParts: 0, fnumberMatch: 0 }
    },
    {
        $merge: { into: "Tournaments", on: "_id", whenMatched: "merge" }
    }
], { allowDiskUse: true });

print("✓ Location dividido e países F[número] extraídos\n");

// Date → StartDate + EndDate
db.Tournaments.aggregate([
    {
        $set: {
            StartDate: {
                $dateFromString: {
                    dateString: { $trim: { input: { $arrayElemAt: [{ $split: ["$Date", " - "] }, 0] } } },
                    format: "%Y.%m.%d",
                    onError: null
                }
            },
            EndDate: {
                $dateFromString: {
                    dateString: { $trim: { input: { $arrayElemAt: [{ $split: ["$Date", " - "] }, 1] } } },
                    format: "%Y.%m.%d",
                    onError: null
                }
            }
        }
    },
    {
        $merge: { into: "Tournaments", on: "_id", whenMatched: "merge" }
    }
], { allowDiskUse: true });

// Normalizar
db.Tournaments.updateMany({ Ground: "" }, { $set: { Ground: "Unknown" } });
db.Tournaments.updateMany({ Prize: "" }, { $set: { Prize: "Unknown" } });

// Grand Slams
const gsPatterns = [/wim/i, /roland\sgarros/i, /australian\sopen/i, /us\s*open/i];
db.Tournaments.find({}, { Tournament: 1 }).forEach(doc => {
    const isGS = gsPatterns.some(r => r.test(doc.Tournament || ""));
    db.Tournaments.updateOne({ _id: doc._id }, { $set: { grand_slam: isGS } });
});

print("✓ Campos processados\n");

